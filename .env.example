# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database (SQLite)
DATABASE_URL=sqlite:storage/reader.db?mode=rwc

# Storage paths
STORAGE_DIR=storage
ASSETS_DIR=storage/assets

# Web frontend path (adjust if needed)
WEB_ROOT=frontend/dist

# Logging
LOG_LEVEL=info

# Request timeout in seconds
REQUEST_TIMEOUT_SECS=15

# Security settings
SECURE=true
SECURE_KEY=

# User registration
INVITE_CODE=
USER_LIMIT=50
USER_BOOK_LIMIT=2000
# 0 means unlimited
USER_LOCAL_BOOK_LIMIT=0
